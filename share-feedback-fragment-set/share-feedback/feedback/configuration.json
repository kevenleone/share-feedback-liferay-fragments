{
    "fieldSets": [
        {
            "fields": [
                {
                    "defaultValue": "tab",
                    "description": "Select the trigger button style",
                    "label": "Trigger Style",
                    "name": "triggerStyle",
                    "type": "select",
                    "typeOptions": {
                        "validValues": [
                            {
                                "value": "icon"
                            },
                            {
                                "value": "tab"
                            }
                        ]
                    }
                },
                {
                    "defaultValue": "Feedback",
                    "description": "Text displayed in the tab trigger (if Tab style is selected)",
                    "label": "Tab Text",
                    "name": "tabText",
                    "type": "text"
                },
                {
                    "defaultValue": "Share Feedback",
                    "description": "Title displayed in the modal header",
                    "label": "Modal Title",
                    "name": "modalTitle",
                    "type": "text"
                },
                {
                    "defaultValue": "#E44B23",
                    "description": "Primary background color (used for tab, header, and submit button)",
                    "label": "Theme Background Color",
                    "name": "tabBackgroundColor",
                    "type": "colorPicker"
                },
                {
                    "defaultValue": "#ffffff",
                    "description": "Primary text color (used for tab, header, and submit button)",
                    "label": "Theme Text Color",
                    "name": "tabTextColor",
                    "type": "colorPicker"
                },
                {
                    "defaultValue": "emoji",
                    "description": "Select the rating type",
                    "label": "Rating Type",
                    "name": "ratingType",
                    "type": "select",
                    "typeOptions": {
                        "validValues": [
                            {
                                "value": "emoji"
                            },
                            {
                                "value": "star"
                            },
                            {
                                "value": "nps"
                            },
                            {
                                "value": "thumbs"
                            },
                            {
                                "value": "none"
                            }
                        ]
                    }
                },
                {
                    "defaultValue": false,
                    "description": "Show optional email field",
                    "label": "Collect Email",
                    "name": "collectEmail",
                    "type": "checkbox"
                },
                {
                    "defaultValue": false,
                    "description": "Allow users to take a screenshot",
                    "label": "Capture Screenshot",
                    "name": "captureScreenshot",
                    "type": "checkbox"
                },
                {
                    "defaultValue": false,
                    "description": "Show category selection dropdown",
                    "label": "Show Category",
                    "name": "showCategory",
                    "type": "checkbox"
                },
                {
                    "defaultValue": "/o/sharefeedbacks",
                    "description": "The URL where the form will be submitted",
                    "label": "Feedback Action URL",
                    "name": "feedbackActionURL",
                    "type": "text"
                },
                {
                    "defaultValue": "bottom-right",
                    "description": "Select the floating button position",
                    "label": "Button Position",
                    "name": "buttonPosition",
                    "type": "select",
                    "typeOptions": {
                        "validValues": [
                            {
                                "value": "bottom-right"
                            },
                            {
                                "value": "bottom-left"
                            },
                            {
                                "value": "middle-right"
                            },
                            {
                                "value": "middle-left"
                            }
                        ]
                    }
                }
            ]
        }
    ]
}
